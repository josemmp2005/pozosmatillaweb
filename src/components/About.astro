---

---

<section id="empresa" class="py-24 bg-white relative overflow-hidden">
	<div class="container mx-auto px-4">
		<div class="flex flex-col lg:flex-row items-center gap-16">
			<!-- Image Container -->
			<div class="lg:w-1/2 relative reveal reveal-left">
				<div
					class="absolute -top-6 -left-6 w-32 h-32 bg-brand-red/10 rounded-full blur-3xl"
				>
				</div>

				<div
					class="absolute -bottom-6 -right-6 w-32 h-32 bg-brand-blue/10 rounded-full blur-3xl"
				>
				</div>

				<div
					class="relative bg-gray-200 rounded-3xl overflow-hidden shadow-2xl border border-gray-100"
				>
					<!-- Generic background image for company's machinery / team -->
					<img
						src="/images/section-foto.png"
						alt="Equipos y maquinaria de Pozos Matilla S.L."
						class="w-full h-[500px] object-cover"
					/>
					<div
						class="absolute bottom-10 left-10 p-3 bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl max-w-sm border-l-4 border-brand-red"
					>
						<p class="text-3xl font-black text-brand-blue mb-2">
							+30 Años
						</p>
						<p
							class="text-sm text-gray-600 font-bold uppercase tracking-wider uppercase"
						>
							De experiencia en el sector
						</p>
					</div>
				</div>
			</div>

			<!-- Text Content -->
			<div class="lg:w-1/2 reveal reveal-right">
				<h2
					class="text-4xl md:text-5xl font-black text-brand-blue mb-6 tracking-tight"
				>
					POZOS MATILLA S.L.
				</h2>
				<h3
					class="text-xl font-bold text-brand-red mb-8 uppercase tracking-widest font-sans"
				>
					Excelencia en Excavación y Perforación
				</h3>

				<div class="space-y-6 text-gray-600 leading-relaxed text-lg">
					<p>
						Ubicados en la localidad de <span
							class="font-bold text-brand-blue"
							>Palma del Río, Córdoba</span
						>, Pozos Matilla S.L. es una empresa familiar que ha
						evolucionado adaptándose a las nuevas tecnologías del
						sector industrial and agrícola.
					</p>
					<p>
						Nuestra misión es proporcionar soluciones rápidas,
						eficaces y seguras para el aprovechamiento de recursos
						hídricos y el desarrollo de infraestructuras sólidas.
						Contamos con un parque de maquinaria propio que nos
						permite afrontar proyectos de cualquier envergadura en
						toda la región de Andalucía.
					</p>
				</div>

				<div class="grid grid-cols-2 gap-8 my-10 reveal reveal-up" style="transition-delay: 200ms">
					<div>
						<p
							class="text-brand-red font-black text-lg mb-1 tracking-tight"
						>
							MAQUINARIA
						</p>
						<p
							class="text-sm font-semibold text-gray-500 uppercase"
						>
							Equipos modernos de perforación
						</p>
					</div>
					<div>
						<p
							class="text-brand-red font-black text-lg mb-1 tracking-tight"
						>
							PROFESIONALES
						</p>
						<p
							class="text-sm font-semibold text-gray-500 uppercase"
						>
							Personal altamente cualificado
						</p>
					</div>
				</div>

				<a
					href="tel:+34608856110"
					class="btn-primary inline-flex items-center gap-3 reveal reveal-up" style="transition-delay: 400ms"
				>
					Habla con nuestro experto
				</a>
			</div>
		</div>
	</div>
</section>
