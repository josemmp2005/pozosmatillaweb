---
import { Image } from 'astro:assets';
import sectionFoto from '../assets/images/section-foto.webp';
---

<section id="empresa" class="py-24 bg-white relative overflow-hidden">
	<div class="container mx-auto px-4">
		<div class="flex flex-col lg:flex-row items-center gap-16">
			<!-- Image Container -->
			<div class="lg:w-1/2 relative reveal reveal-left">
				<div
					class="absolute -top-6 -left-6 w-32 h-32 bg-brand-red/10 rounded-full blur-3xl"
				>
				</div>

				<div
					class="absolute -bottom-6 -right-6 w-32 h-32 bg-brand-blue/10 rounded-full blur-3xl"
				>
				</div>
				<div
					class="absolute -top-10 -left-10 w-40 h-40 bg-brand-red/10 rounded-full blur-3xl animate-pulse"
				>
				</div>
				<div
					class="absolute -bottom-10 -right-10 w-40 h-40 bg-brand-blue/10 rounded-full blur-3xl animate-pulse"
					style="animation-delay: 1s"
				>
				</div>

				<div class="relative group">
					<div
						class="absolute inset-0 bg-brand-red translate-x-4 translate-y-4 rounded-[40px] opacity-10 group-hover:translate-x-6 group-hover:translate-y-6 transition-transform duration-700"
					>
					</div>
					<div
						class="relative bg-gray-100 rounded-[40px] overflow-hidden shadow-2xl border border-gray-100 ring-1 ring-black/5"
					>
						<Image
							src={sectionFoto}
							alt="Equipos y maquinaria de Pozos Matilla S.L."
							class="w-full h-[600px] object-cover transition-transform duration-[2s] group-hover:scale-105"
						/>

						<!-- Floating Experience Badge -->
						<div
							class="absolute bottom-10 left-10 p-8 bg-white/95 backdrop-blur-md rounded-[32px] shadow-2xl max-w-[240px] border border-white/20 reveal reveal-up"
							style="transition-delay: 500ms"
						>
							<div class="flex items-center gap-3 mb-2">
								<span
									class="text-5xl font-bold text-brand-red tracking-tighter"
									>+30</span
								>
								<span class="w-10 h-[2px] bg-brand-blue/20"
								></span>
							</div>
							<p
								class="text-brand-blue font-bold uppercase tracking-widest text-xs leading-tight"
							>
								Años de Liderazgo Técnico en el Sector
							</p>
						</div>
					</div>
				</div>
			</div>

			<!-- Text Content -->
			<div class="lg:w-1/2 reveal reveal-right">
				<div
					class="inline-flex items-center gap-2 px-3 py-1 bg-brand-blue/5 border border-brand-blue/10 rounded-full mb-6"
				>
					<span class="w-1.5 h-1.5 bg-brand-blue rounded-full"></span>
					<span
						class="text-[10px] font-bold uppercase tracking-[0.2em] text-brand-blue"
						>Sobre Nuestra Empresa</span
					>
				</div>

				<h2
					class="text-5xl md:text-6xl font-bold text-brand-blue mb-8 tracking-tighter uppercase leading-none"
				>
					PASIÓN POR EL <span class="text-brand-red"
						>TRABAJO BIEN HECHO</span
					>
				</h2>

				<h3
					class="text-lg font-bold text-gray-400 mb-10 uppercase tracking-[0.3em] font-sans border-l-4 border-brand-red pl-6"
				>
					Excelencia en Excavación y Perforación
				</h3>

				<div
					class="space-y-8 text-gray-600 leading-relaxed text-xl font-medium"
				>
					<p>
						Ubicados en <span class="text-brand-blue font-bold"
							>Palma del Río, Córdoba</span
						>, Pozos Matilla S.L. es una empresa familiar que ha
						liderado el sector gracias a su capacidad de adaptación
						y vanguardia tecnológica.
					</p>
					<p
						class="text-gray-500 italic border-l-2 border-gray-100 pl-6"
					>
						"Nuestra misión es proporcionar soluciones eficaces y
						seguras para el aprovechamiento de recursos hídricos y
						el desarrollo de infraestructuras sólidas en toda
						Andalucía."
					</p>
				</div>

				<div
					class="grid grid-cols-2 gap-10 my-12 reveal reveal-up"
					style="transition-delay: 300ms"
				>
					<div class="group/item">
						<p
							class="text-brand-red font-bold text-xl mb-2 tracking-tight group-hover/item:translate-x-2 transition-transform"
						>
							VANGUARDIA
						</p>
						<div
							class="w-8 h-1 bg-gray-100 mb-3 group-hover/item:w-full transition-all duration-500"
						>
						</div>
						<p
							class="text-sm font-bold text-gray-400 uppercase tracking-widest leading-tight"
						>
							Equipos modernos de perforación y excavación
						</p>
					</div>
					<div class="group/item">
						<p
							class="text-brand-red font-bold text-xl mb-2 tracking-tight group-hover/item:translate-x-2 transition-transform"
						>
							EQUIPO HUMANO
						</p>
						<div
							class="w-8 h-1 bg-gray-100 mb-3 group-hover/item:w-full transition-all duration-500"
						>
						</div>
						<p
							class="text-sm font-bold text-gray-400 uppercase tracking-widest leading-tight"
						>
							Personal técnico altamente cualificado y certificado
						</p>
					</div>
				</div>

				<div class="pt-8">
					<a
						href="tel:+34608856110"
						class="btn-primary !px-10 !py-5 inline-flex items-center gap-4 text-xl group shadow-xl shadow-brand-red/10"
					>
						Consultar con un Experto
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="3"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="transition-transform group-hover:translate-x-2"
							><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"
							></path></svg
						>
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
