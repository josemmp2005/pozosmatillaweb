---
---

<section
	id="inicio"
	class="relative min-h-[100vh] flex items-center pt-20 overflow-hidden"
>
	<!-- Background Image with Overlay -->
	<div class="absolute inset-0 z-0">
		<video
			data-src="/videos/hero.mp4"
			autoplay
			loop
			muted
			playsinline
			preload="none"
			poster="/images/hero.webp"
			aria-hidden="true"
			id="hero-video"
			class="w-full h-full object-cover scale-x-[-1]"></video>
		<div
			class="absolute inset-0 bg-gradient-to-r from-brand-blue/60 via-brand-blue/60 to-transparent"
		>
		</div>
	</div>

	<div class="container mx-auto px-4 z-10">
		<div class="max-w-4xl text-white">
			<div
				class="inline-block px-4 py-1 rounded-2xl mb-6 reveal reveal-up border border-red/50"
			>
				<span class="text-xs font-bold uppercase tracking-[0.3em]"
					>Confianza y Experiencia</span
				>
			</div>

			<h1
				class="text-5xl md:text-7xl lg:text-8xl font-bold mb-6 leading-none tracking-tighter reveal reveal-up"
				style="transition-delay: 200ms"
			>
				<span class="block">SOLUCIONES EN</span>
				<span class="text-brand-red brand-text-shadow"
					>POZOS Y EXCAVACIONES</span
				>
			</h1>

			<p
				class="text-lg md:text-xl text-gray-200 mb-10 max-w-2xl reveal reveal-up"
				style="transition-delay: 400ms"
			>
				En <span class="font-bold text-white">Pozos Matilla S.L.</span> somos
				especialistas en perforaciones, pozos y movimientos de tierra en Palma
				del Río, comarca y toda Andalucía. Más de 30 años de experiencia técnica
				a su servicio.
			</p>

			<div
				class="flex flex-col sm:flex-row gap-4 reveal reveal-up"
				style="transition-delay: 600ms"
			>
				<a
					href="#servicios"
					class="btn-primary flex items-center justify-center gap-2 text-lg"
				>
					Nuestros Servicios
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="lucide lucide-arrow-down"
						><path d="M12 5v14"></path><path d="m19 12-7 7-7-7"
						></path></svg
					>
				</a>
				<a
					href="#contacto"
					class="btn-secondary flex items-center justify-center gap-2 text-lg border border-white/20"
				>
					Solicitar Presupuesto
				</a>
			</div>
		</div>
	</div>

	<!-- Stats / Features Quick Bar -->
	<div
		class="absolute bottom-0 left-0 w-full bg-white/10 backdrop-blur-md border-t border-white/10 py-6 hidden lg:block"
	>
		<div
			class="container mx-auto px-4 flex justify-between items-center text-white"
		>
			<div class="flex items-center gap-4">
				<div class="p-3 bg-brand-red rounded-full">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="lucide lucide-check-circle"
						><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"
						></path><polyline points="22 4 12 14.01 9 11.01"
						></polyline></svg
					>
				</div>
				<div>
					<p class="font-bold text-xl leading-none uppercase">
						Legalización
					</p>
					<p
						class="text-xs text-gray-300 uppercase tracking-widest mt-1"
					>
						Gestión de trámites
					</p>
				</div>
			</div>

			<div class="flex items-center gap-4">
				<div class="p-3 bg-brand-red rounded-full">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="lucide lucide-hard-hat"
						><path
							d="M2 18a1 1 0 0 0 1 1h18a1 1 0 0 0 1-1v-2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v2z"
						></path><path
							d="M10 10V5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5"
						></path><path d="M4 15v-3a6 6 0 0 1 12 0v3"></path></svg
					>
				</div>
				<div>
					<p class="font-bold text-xl leading-none uppercase">
						Garantía Total
					</p>
					<p
						class="text-xs text-gray-300 uppercase tracking-widest mt-1"
					>
						Seguridad en cada obra
					</p>
				</div>
			</div>

			<div class="flex items-center gap-4">
				<div class="p-3 bg-brand-red rounded-full">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="lucide lucide-map-pin"
						><path
							d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
						></path><circle cx="12" cy="10" r="3"></circle></svg
					>
				</div>
				<div>
					<p class="font-bold text-xl leading-none uppercase">
						Alcance Regional
					</p>
					<p
						class="text-xs text-gray-300 uppercase tracking-widest mt-1"
					>
						Andalucía y alrededores
					</p>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	function initHeroVideo() {
		const video = document.getElementById("hero-video") as HTMLVideoElement | null;
		if (!video) return;

		const videoSrc = video.dataset.src;
		if (!videoSrc) return;

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					if (!video.getAttribute("src")) {
						video.src = videoSrc;
					}
					video
						.play()
						.catch(() => {
							// Autoplay can be blocked in some contexts; poster remains visible.
						});
					observer.disconnect();
				});
			},
			{ threshold: 0.1 },
		);

		observer.observe(video);
	}

	initHeroVideo();
</script>
