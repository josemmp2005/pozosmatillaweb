---
import { Image } from 'astro:assets';
import bento1 from '../assets/images/bento1.webp';
import bento2 from '../assets/images/bento2.webp';
import bento4 from '../assets/images/bento4.webp';
import heroImg from '../assets/images/section-foto.webp';

const galleryItems = [
	{ 
		type: 'video', 
		src: '/videos/bento-video2.mp4', 
		alt: 'Perforación en terreno rocoso',
		category: 'En Acción',
		stats: 'Córdoba',
		span: 'md:col-span-1 md:row-span-2' 
	},
	{ 
		type: 'image', 
		src: bento2, 
		alt: 'Cimentaciones Especiales',
		category: 'Cimentación',
		stats: 'Obras Civiles',
		span: 'md:col-span-2 md:row-span-2'
	},
	{ 
		type: 'video', 
		src: '/videos/bento-video1.mp4', 
		alt: 'Video de obra actual',
		category: 'En Acción',
		stats: 'Palma del Río',
		span: 'md:col-span-1 md:row-span-2' 
	},
	{ 
		type: 'image', 
		src: bento1, 
		alt: 'Maquinaria de Última Generación',
		category: 'Flota Industrial',
		stats: 'Maquinaria Propia',
		span: 'md:col-span-2 md:row-span-1' 
	},
	{ 
		type: 'video', 
		src: '/videos/bento-video3.mp4', 
		alt: 'Excavación para cimentación',
		category: 'Excavaciones',
		stats: 'Córdoba',
		span: 'md:col-span-1 md:row-span-1' 
	},
	{ 
		type: 'image', 
		src: bento4, 
		alt: 'Perforaciones para Pozos',
		category: 'Captaciones',
		stats: 'Maquinaria Especializada',
		span: 'md:col-span-1 md:row-span-1' 
	}
];
---

<section id="galeria" class="py-24 bg-gray-950 text-white relative overflow-hidden">
	<div class="absolute top-0 right-0 w-1/3 h-1/3 bg-brand-red/5 blur-[120px] rounded-full -translate-y-1/2 translate-x-1/2"></div>
	<div class="absolute bottom-0 left-0 w-1/3 h-1/3 bg-brand-blue/5 blur-[120px] rounded-full translate-y-1/2 -translate-x-1/2"></div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6 reveal reveal-up">
			<div class="max-w-2xl">
				<div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-red/10 border border-brand-red/20 rounded-full mb-4">
					<span class="w-1.5 h-1.5 bg-brand-red rounded-full animate-pulse"></span>
					<span class="text-xs font-bold uppercase tracking-widest text-brand-red">Proyectos Reales</span>
				</div>
				<h2 class="text-4xl md:text-6xl font-bold tracking-tight uppercase leading-none">
					NUESTROS <span class="text-brand-red">PROYECTOS</span> <br />
					DE <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-400 to-white">Referencia</span>
				</h2>
			</div>
			<p class="text-gray-400 text-lg max-w-sm md:text-right font-medium">
				Visualice nuestra maquinaria en acción y la calidad de nuestros acabados en trabajos industriales y agrícolas.
			</p>
		</div>

		<!-- Bento Grid -->
		<div class="grid grid-cols-1 md:grid-cols-4 auto-rows-[300px] gap-4 md:gap-6 reveal-group">
			{galleryItems.map((item) => (
				<div 
					class={`group relative overflow-hidden rounded-3xl border border-white/5 bg-gray-900/50 backdrop-blur-sm transition-all duration-700 hover:border-white/20 hover:shadow-[0_20px_50px_rgba(0,0,0,0.5)] cursor-pointer bento-item reveal reveal-up ${item.span}`}
					data-src={typeof item.src === 'string' ? item.src : (item.src as ImageMetadata).src}
					data-type={item.type}
					data-alt={item.alt}
				>
					
					{item.type === 'image' ? (
						<>
							<Image 
								src={item.src as ImageMetadata} 
								alt={item.alt} 
								width={640}
								height={480}
								sizes="(max-width: 767px) 92vw, (max-width: 1023px) 48vw, 24vw"
								quality={55}
								loading="lazy"
								decoding="async"
								class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 grayscale-[0.2] group-hover:grayscale-0 opacity-80 group-hover:opacity-100"
							/>
							
							<!-- Floating Badges -->
							<div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
								<span class="px-3 py-1 bg-black/50 backdrop-blur-md border border-white/10 rounded-full text-[10px] font-bold uppercase tracking-wider text-white opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-[-10px] group-hover:translate-y-0">
									{item.category}
								</span>
							</div>

							<!-- Bottom Overlay Content -->
							<div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/20 to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-500"></div>
							
							<div class="absolute bottom-0 left-0 w-full p-6 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
								<p class="text-brand-red font-bold text-xs uppercase tracking-[0.2em] mb-1 drop-shadow-lg">{item.stats}</p>
								<h3 class="text-white font-normal text-xl md:text-2xl uppercase tracking-tighter leading-none mb-1">{item.alt}</h3>
								<div class="w-0 group-hover:w-16 h-1 bg-brand-red transition-all duration-700 delay-100"></div>
							</div>
						</>
					) : (
						<div class="relative w-full h-full flex flex-col items-center justify-center bg-gray-950 overflow-hidden">
							<video 
								data-src={item.src as string}
								muted 
								loop 
								playsinline 
								preload="none"
								class="absolute inset-0 w-full h-full object-cover opacity-40 group-hover:opacity-60 transition-opacity duration-700"
							/>
							
							<!-- Floating Badges for Video -->
							<div class="absolute top-4 left-4 z-20 flex flex-col gap-2">
								<span class="px-3 py-1 bg-brand-red/80 backdrop-blur-md border border-white/10 rounded-full text-[10px] font-bold uppercase tracking-wider text-white opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-[-10px] group-hover:translate-y-0">
									{item.category}
								</span>
							</div>

							<!-- Bottom Overlay Content for Video -->
							<div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-transparent to-transparent opacity-60 group-hover:opacity-90 transition-opacity duration-500"></div>
							
							<div class="absolute bottom-0 left-0 w-full p-6 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 z-10">
								<p class="text-brand-red font-bold text-xs uppercase tracking-[0.2em] mb-1 drop-shadow-lg">{item.stats}</p>
								<h3 class="text-white font-normal text-xl md:text-2xl uppercase tracking-tighter leading-none mb-1">{item.alt}</h3>
								<div class="w-0 group-hover:w-16 h-1 bg-brand-red transition-all duration-700 delay-100"></div>
							</div>
						</div>
					)}
					
					<!-- Card Shine Effect -->
					<div class="absolute top-0 -left-full w-full h-full bg-gradient-to-r from-transparent via-white/5 to-transparent group-hover:left-[200%] transition-all duration-1000 ease-in-out pointer-events-none"></div>
				</div>
			))}
		</div>

		<!-- Footer Action Card -->
		<div class="mt-20 relative rounded-[40px] overflow-hidden bg-brand-blue/10 border border-white/10 group reveal reveal-up">
			<!-- Decorative image background for CTA -->
			<div class="absolute inset-0 opacity-10 grayscale group-hover:opacity-20 transition-opacity duration-700">
				<Image src={heroImg} alt="" loading="lazy" decoding="async" width={960} height={540} quality={50} sizes="(max-width: 1023px) 100vw, 960px" class="w-full h-full object-cover" />
			</div>
			
			<div class="relative z-10 p-10 md:p-16 flex flex-col md:flex-row items-center justify-between gap-10">
				<div class="text-center md:text-left max-w-xl">
					<h3 class="text-4xl md:text-5xl font-bold mb-4 tracking-tighter uppercase leading-none">¿TIENE UN <span class="text-brand-red">PROYECTO</span> EN MENTE?</h3>
					<p class="text-gray-400 text-lg md:text-xl font-medium">Hable directamente con nuestros técnicos para una valoración sin compromiso.</p>
				</div>
				<div class="flex flex-col sm:flex-row gap-4 items-center">
					<a href="tel:+34608856110" class="btn-primary !px-10 !py-6 flex items-center gap-4 text-2xl shadow-2xl shadow-brand-red/20 group/btn">
						<img src="/icon/call.svg" alt="" class="w-8 h-8 group-hover/btn:animate-bounce" />
						608 856 110
					</a>
				</div>
			</div>
		</div>
	</div>

	<!-- Lightbox Modal -->
	<div id="lightbox" class="fixed inset-0 z-[200] hidden items-center justify-center bg-black/95 backdrop-blur-2xl opacity-0 transition-opacity duration-500">
		<button id="close-lightbox" class="absolute top-8 right-8 text-white/50 hover:text-white transition-colors duration-300 z-50 p-2" aria-label="Cerrar">
			<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
		</button>
		
		<div id="lightbox-content" class="relative w-full max-w-6xl max-h-[90vh] px-4 scale-90 opacity-0 transition-all duration-500 flex items-center justify-center">
			<!-- Content will be injected here -->
		</div>
		
		<!-- Floating caption in lightbox -->
		<div id="lightbox-caption" class="absolute bottom-12 left-1/2 -translate-x-1/2 text-center w-full px-6 opacity-0 translate-y-10 transition-all duration-700">
			<h4 class="text-white text-2xl md:text-4xl font-bold uppercase tracking-tighter drop-shadow-2xl"></h4>
		</div>
	</div>
</section>

<style>
	/* Custom styles for bento cards if needed beyond Tailwind */
	#galeria {
		background-image: 
			radial-gradient(circle at 2px 2px, rgba(255,255,255,0.02) 1px, transparent 0);
		background-size: 40px 40px;
	}

	#lightbox.active {
		display: flex;
		opacity: 1;
	}

	#lightbox.active #lightbox-content {
		scale: 1;
		opacity: 1;
	}

	#lightbox.active #lightbox-caption {
		opacity: 1;
		translate-y: 0;
	}
</style>

<script>
	function initLightbox() {
		const lightbox = document.getElementById('lightbox');
		const closeBtn = document.getElementById('close-lightbox');
		const content = document.getElementById('lightbox-content');
		const caption = document.querySelector('#lightbox-caption h4');
		const captionContainer = document.getElementById('lightbox-caption');
		const items = document.querySelectorAll('.bento-item');
		const body = document.body;

		if (!lightbox || !closeBtn || !content || !items) return;
		if (lightbox.dataset.bound === 'true') return;
		lightbox.dataset.bound = 'true';

		const isMobile = window.matchMedia('(max-width: 767px)').matches;

		const inlineVideos = document.querySelectorAll("#galeria video[data-src]") as NodeListOf<HTMLVideoElement>;
		if (!isMobile) {
			const mediaObserver = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						const video = entry.target as HTMLVideoElement;
						if (entry.isIntersecting) {
							if (!video.src) {
								const src = video.dataset.src;
								if (src) video.src = src;
							}
							video.play().catch(() => {});
						} else {
							video.pause();
						}
					});
				},
				{ threshold: 0.2 },
			);

			inlineVideos.forEach((video) => mediaObserver.observe(video));
		}

		function openLightbox(item: any) {
			const src = item.getAttribute('data-src');
			const type = item.getAttribute('data-type');
			const alt = item.getAttribute('data-alt');

			if (!src || !type || !content || !caption) return;

			// Clear previous content
			content.innerHTML = '';
			
			if (type === 'image') {
				const img = document.createElement('img');
				img.src = src;
				img.alt = alt || '';
				img.className = 'max-w-full max-h-[85vh] object-contain rounded-xl shadow-2xl shadow-black/80';
				content.appendChild(img);
			} else if (type === 'video') {
				const video = document.createElement('video');
				video.src = src;
				video.controls = true;
				video.autoplay = true;
				video.className = 'max-w-full max-h-[85vh] rounded-xl shadow-2xl shadow-black/80';
				content.appendChild(video);
			}

			if(caption) caption.textContent = alt || '';
			
			if (lightbox) {
				lightbox.classList.add('active');
			}
			body.classList.add('lightbox-is-open');
			body.style.overflow = 'hidden';
		}

		function closeLightbox() {
			if (!lightbox) return;
			lightbox.classList.remove('active');
			body.classList.remove('lightbox-is-open');
			body.style.overflow = '';
			
			// Wait for animation to clear content
			setTimeout(() => {
				if(content) content.innerHTML = '';
			}, 500);
		}

		items.forEach(item => {
			item.addEventListener('click', () => openLightbox(item));
		});

		closeBtn.addEventListener('click', closeLightbox);
		
		// Close on clicking outside the content
		lightbox.addEventListener('click', (e) => {
			if (e.target === lightbox) closeLightbox();
		});

		// Keyboard support
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && lightbox && lightbox.classList.contains('active')) {
				closeLightbox();
			}
		});
	}

	// Initialize on page load and on Astro swap
	initLightbox();
</script>

