---

---

<section id="contacto" class="py-24 bg-white overflow-hidden relative">
	<!-- Background subtle pattern -->
	<div
		class="absolute inset-0 opacity-[0.03] pointer-events-none"
		style="background-image: radial-gradient(#102f75 1px, transparent 1px); background-size: 32px 32px;"
	>
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<!-- Contact Information Banner -->
		<div class="max-w-6xl mx-auto bg-brand-blue p-12 md:p-20 rounded-[40px] text-white shadow-[0_30px_60px_rgba(16,47,117,0.25)] relative overflow-hidden reveal reveal-up">
			<!-- Decorative Gradients -->
			<div class="absolute -top-20 -right-20 w-80 h-80 bg-brand-red/20 rounded-full blur-[80px] pointer-events-none"></div>
			<div class="absolute -bottom-20 -left-20 w-80 h-80 bg-white/5 rounded-full blur-[80px] pointer-events-none"></div>

			<div class="text-center mb-16 relative z-10">
				<h2 class="text-4xl md:text-5xl font-bold mb-6 tracking-tighter uppercase tracking-[0.2em] text-brand-red">
					CONTACTO DIRECTO
				</h2>
				<p class="text-gray-300 text-lg md:text-xl font-medium leading-relaxed max-w-3xl mx-auto">
					Contacte con nosotros utilizando su método preferido. Nuestros técnicos especialistas le atenderán directamente desde Palma del Río para toda España.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
				<!-- Phone -->
				<a href="tel:+34608856110" class="flex flex-col items-center text-center gap-6 group p-10 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-brand-red/30 hover:-translate-y-2 transition-all duration-500 shadow-xl">
					<div class="w-20 h-20 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:-rotate-12 border border-white/10 shadow-lg">
						<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
					</div>
					<div>
						<p class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-red mb-3 opacity-90">Teléfono Directo</p>
						<p class="text-3xl font-bold tracking-tighter leading-none group-hover:text-brand-red transition-colors">608 856 110</p>
					</div>
				</a>

				<!-- Email -->
				<a href="mailto:pozosfranciscomatilla@gmail.com" class="flex flex-col items-center text-center gap-6 group p-10 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-brand-red/30 hover:-translate-y-2 transition-all duration-500 shadow-xl">
					<div class="w-20 h-20 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:rotate-12 border border-white/10 shadow-lg">
						<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail"><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path><rect width="20" height="16" x="2" y="5" rx="2"></rect></svg>
					</div>
					<div>
						<p class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-red mb-3 opacity-90">Email Técnico</p>
						<p class="text-lg font-bold tracking-tighter leading-tight break-all group-hover:text-brand-red transition-colors">pozosfranciscomatilla@gmail.com</p>
					</div>
				</a>

				<!-- Location -->
				<div class="flex flex-col items-center text-center gap-6 group p-10 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-brand-red/30 hover:-translate-y-2 transition-all duration-500 shadow-xl cursor-default">
					<div class="w-20 h-20 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:-rotate-12 border border-white/10 shadow-lg">
						<svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle></svg>
					</div>
					<div>
						<p class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-red mb-3 opacity-90">Ubicación</p>
						<p class="text-2xl font-bold uppercase tracking-tighter leading-none">Palma del Río, Córdoba</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
