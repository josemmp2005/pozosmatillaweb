---

---

<section id="contacto" class="py-24 bg-white overflow-hidden relative">
	<!-- Background subtle pattern -->
	<div
		class="absolute inset-0 opacity-[0.03] pointer-events-none"
		style="background-image: radial-gradient(#102f75 1px, transparent 1px); background-size: 32px 32px;"
	>
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="flex flex-col lg:flex-row gap-16">
			<!-- Contact Information -->
			<div
				class="lg:w-1/3 bg-brand-blue p-12 rounded-[40px] text-white shadow-[0_30px_60px_rgba(16,47,117,0.25)] relative overflow-hidden reveal reveal-left"
			>
				<div
					class="absolute -top-10 -right-10 w-40 h-40 bg-brand-red/20 rounded-full blur-3xl"
				>
				</div>

				<h2
					class="text-4xl font-bold mb-8 tracking-tighter uppercase tracking-[0.2em] text-brand-red"
				>
					CONTACTO
				</h2>
				<p
					class="text-gray-300 mb-12 text-lg font-medium leading-relaxed italic"
				>
					Estamos a su disposición para cualquier duda o consulta
					técnica. Infórmese sin compromiso.
				</p>

				<div class="space-y-12">
					<div class="flex items-start gap-6 group">
						<div
							class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:-rotate-12 border border-white/10 shadow-lg"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="30"
								height="30"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-phone"
								><path
									d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
								></path></svg
							>
						</div>
						<div>
							<p
								class="text-[10px] font-bold uppercase tracking-widest text-brand-red mb-2 opacity-80"
							>
								Teléfono Directo
							</p>
							<a
								href="tel:+34608856110"
								class="text-3xl font-bold hover:text-brand-red transition-colors tracking-tighter leading-none"
								>608 856 110</a
							>
						</div>
					</div>

					<div class="flex items-start gap-6 group">
						<div
							class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:rotate-12 border border-white/10 shadow-lg"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="30"
								height="30"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-mail"
								><path
									d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
								></path><rect
									width="20"
									height="16"
									x="2"
									y="5"
									rx="2"></rect></svg
							>
						</div>
						<div>
							<p
								class="text-[10px] font-bold uppercase tracking-widest text-brand-red mb-2 opacity-80"
							>
								Email Técnico
							</p>
							<a
								href="mailto:pozosfranciscomatilla@gmail.com"
								class="text-xl font-bold hover:text-brand-red transition-colors break-all tracking-tighter leading-tight"
								>pozosfranciscomatilla@gmail.com</a
							>
						</div>
					</div>

					<div class="flex items-start gap-6 group">
						<div
							class="w-16 h-16 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:-rotate-12 border border-white/10 shadow-lg"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="30"
								height="30"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="lucide lucide-map-pin"
								><path
									d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
								></path><circle cx="12" cy="10" r="3"
								></circle></svg
							>
						</div>
						<div>
							<p
								class="text-[10px] font-bold uppercase tracking-widest text-brand-red mb-2 opacity-80"
							>
								Ubicación
							</p>
							<p
								class="text-2xl font-bold leading-none uppercase tracking-tighter"
							>
								Palma del Río, Córdoba, España
							</p>
						</div>
					</div>
				</div>
			</div>

			<!-- Contact Form -->
			<div class="lg:w-2/3 reveal reveal-right">
				<form
					id="contact-form"
					class="bg-gray-50 p-12 md:p-16 rounded-[40px] border border-gray-100 shadow-[0_20px_40px_rgba(0,0,0,0.02)] relative overflow-hidden group"
				>
					<div
						class="absolute top-0 right-0 w-64 h-64 bg-brand-red/[0.02] rounded-full blur-3xl pointer-events-none group-hover:bg-brand-red/5 transition-colors duration-700"
					>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
						<div class="space-y-4">
							<label
								for="name"
								class="block text-xs font-bold text-brand-blue uppercase tracking-[0.2em] opacity-60"
								>Nombre Completo</label
							>
							<input
								type="text"
								id="name"
								name="name"
								required
								class="w-full px-8 py-6 rounded-2xl bg-white border border-gray-100 focus:outline-none focus:ring-4 focus:ring-brand-red/10 focus:border-brand-red transition-all font-bold text-gray-800 shadow-sm"
								placeholder="Nombre completo"
							/>
						</div>
						<div class="space-y-4">
							<label
								for="phone"
								class="block text-xs font-bold text-brand-blue uppercase tracking-[0.2em] opacity-60"
								>Teléfono Directo</label
							>
							<input
								type="tel"
								id="phone"
								name="phone"
								required
								class="w-full px-8 py-6 rounded-2xl bg-white border border-gray-100 focus:outline-none focus:ring-4 focus:ring-brand-red/10 focus:border-brand-red transition-all font-bold text-gray-800 shadow-sm"
								placeholder="600 00 00 00"
							/>
						</div>
					</div>

					<div class="space-y-4 mb-12">
						<label
							for="service"
							class="block text-xs font-bold text-brand-blue uppercase tracking-[0.2em] opacity-60"
							>Servicio de interés</label
						>
						<select
							id="service"
							name="service"
							class="w-full px-8 py-6 rounded-2xl bg-white border border-gray-100 focus:outline-none focus:ring-4 focus:ring-brand-red/10 focus:border-brand-red transition-all font-bold text-gray-800 shadow-sm appearance-none cursor-pointer"
						>
							<option>Construcción de Pozos</option>
							<option>Excavaciones y Tierras</option>
							<option>Perforaciones Especiales</option>
							<option>Legalización / Otros</option>
						</select>
					</div>

					<div class="space-y-4 mb-16">
						<label
							for="message"
							class="block text-xs font-bold text-brand-blue uppercase tracking-[0.2em] opacity-60"
							>Mensaje / Detalles</label
						>
						<textarea
							id="message"
							name="message"
							rows="5"
							class="w-full px-8 py-6 rounded-2xl bg-white border border-gray-100 focus:outline-none focus:ring-4 focus:ring-brand-red/10 focus:border-brand-red transition-all font-bold text-gray-800 shadow-sm resize-none"
							placeholder="Cuéntenos sobre su proyecto..."
						></textarea>
					</div>

					<button
						type="submit"
						class="btn-primary w-full text-2xl py-7 !flex items-center justify-center gap-6 shadow-[0_20px_50px_rgba(220,33,28,0.25)] group hover:-translate-y-1 transition-all"
					>
						Enviar Solicitud Profesional
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="28"
							height="28"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="3"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="transition-transform group-hover:translate-x-3 group-hover:-translate-y-3"
							><path d="M22 2 11 13"></path><path
								d="m22 2-7 20-4-9-9-4Z"></path></svg
						>
					</button>
				</form>

				<!-- Success Message (Hidden by default) -->
				<div id="contact-success" class="hidden bg-brand-blue p-12 md:p-20 rounded-[40px] text-center text-white shadow-2xl reveal reveal-up items-center justify-center flex-col min-h-[500px]">
					<div class="w-24 h-24 bg-brand-red rounded-full flex items-center justify-center mb-8 animate-bounce shadow-[0_0_30px_rgba(220,33,28,0.4)]">
						<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><path d="M20 6 9 17l-5-5"/></svg>
					</div>
					<h3 class="text-4xl md:text-5xl font-bold mb-6 tracking-tighter uppercase tracking-[0.2em]">¡SOLICITUD <span class="text-brand-red">RECIBIDA</span>!</h3>
					<p class="text-gray-300 text-xl font-medium leading-relaxed max-w-md mx-auto mb-10">
						Hemos recibido sus detalles correctamente. Un técnico especialista revisará su caso y le contactará en menos de 24 horas.
					</p>
					<button onclick="window.location.reload()" class="text-white/50 hover:text-white font-bold uppercase tracking-widest text-sm transition-colors border-b border-white/10 pb-1">
						Enviar otro mensaje
					</button>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	function initContactForm() {
		const form = document.getElementById('contact-form') as HTMLFormElement;
		const successMsg = document.getElementById('contact-success');
		const submitBtn = form?.querySelector('button[type="submit"]');

		if (!form || !successMsg || !submitBtn) return;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			
			// Change button state
			const originalBtnContent = submitBtn.innerHTML;
			submitBtn.setAttribute('disabled', 'true');
			submitBtn.innerHTML = `
				<svg class="animate-spin h-6 w-6 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
					<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
					<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
				</svg>
				Procesando Solución...
			`;

			// Simulate API call
			await new Promise(resolve => setTimeout(resolve, 1800));

			// Smooth transition to success
			form.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
			setTimeout(() => {
				form.style.display = 'none';
				successMsg.classList.remove('hidden');
				successMsg.classList.add('flex');
				window.scrollTo({
					top: (document.getElementById('contacto')?.offsetTop || 0) - 100,
					behavior: 'smooth'
				});
			}, 400);
		});
	}

	// Initialize
	initContactForm();
	document.addEventListener('astro:after-swap', initContactForm);
</script>
