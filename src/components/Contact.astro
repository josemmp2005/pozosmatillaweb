---
---

<section id="contacto" class="py-24 bg-white overflow-hidden">
	<div class="container mx-auto px-4">
		<div class="flex flex-col lg:flex-row gap-16">
			<!-- Contact Information -->
			<div class="lg:w-1/3 bg-brand-blue p-12 rounded-[40px] text-white shadow-2xl relative overflow-hidden reveal reveal-left">
				<div class="absolute -top-10 -right-10 w-40 h-40 bg-brand-red/20 rounded-full blur-3xl"></div>
				
				<h2 class="text-4xl font-black mb-8 tracking-tight uppercase tracking-[0.2em] text-brand-red">CONTACTO</h2>
				<p class="text-gray-300 mb-12 text-lg font-medium leading-relaxed">Estamos a su disposición para cualquier duda o consulta técnica. Infórmese sin compromiso.</p>

				<div class="space-y-10">
					<div class="flex items-start gap-5 group">
						<div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:rotate-6">
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-phone"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
						</div>
						<div>
							<p class="text-xs font-black uppercase tracking-widest text-brand-red mb-1">Teléfono Directo</p>
							<a href="tel:+34608856110" class="text-2xl font-black hover:text-brand-red transition-colors tracking-tighter">608 856 110</a>
						</div>
					</div>

					<div class="flex items-start gap-5 group">
						<div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:rotate-6">
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-mail"><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/><rect width="20" height="16" x="2" y="5" rx="2"/></svg>
						</div>
						<div>
							<p class="text-xs font-black uppercase tracking-widest text-brand-red mb-1">Email Técnico</p>
							<a href="mailto:pozosfranciscomatilla@gmail.com" class="text-xl font-black hover:text-brand-red transition-colors break-all tracking-tighter">pozosfranciscomatilla@gmail.com</a>
						</div>
					</div>

					<div class="flex items-start gap-5 group">
						<div class="w-14 h-14 bg-white/10 rounded-2xl flex items-center justify-center shrink-0 group-hover:bg-brand-red transition-all duration-500 group-hover:rotate-6">
							<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
						</div>
						<div>
							<p class="text-xs font-black uppercase tracking-widest text-brand-red mb-1">Ubicación</p>
							<p class="text-xl font-black leading-tight uppercase tracking-tighter">Palma del Río, Córdoba, España</p>
						</div>
					</div>
				</div>
			</div>

			<!-- Contact Form -->
			<div class="lg:w-2/3 reveal reveal-right">
				<form id="contact-form" class="bg-gray-50 p-10 md:p-14 rounded-[40px] border border-gray-100 shadow-sm relative overflow-hidden">
					<div class="absolute top-0 right-0 w-32 h-32 bg-brand-red/5 rounded-full blur-3xl"></div>
					
					<div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-10">
						<div class="space-y-4">
							<label for="name" class="block text-sm font-black text-brand-blue uppercase tracking-widest">Nombre Completo</label>
							<input type="text" id="name" name="name" required class="w-full px-8 py-5 rounded-2xl border border-gray-200 focus:outline-none focus:ring-4 focus:ring-brand-red/10 focus:border-brand-red transition-all font-semibold" placeholder="Nombre completo">
						</div>
						<div class="space-y-4">
							<label for="phone" class="block text-sm font-black text-brand-blue uppercase tracking-widest">Teléfono Directo</label>
							<input type="tel" id="phone" name="phone" required class="w-full px-8 py-5 rounded-2xl border border-gray-200 focus:outline-none focus:ring-4 focus:ring-brand-red/10 focus:border-brand-red transition-all font-semibold" placeholder="600 00 00 00">
						</div>
					</div>
					
					<div class="space-y-4 mb-10">
						<label for="service" class="block text-sm font-black text-brand-blue uppercase tracking-widest">Servicio de interés</label>
						<select id="service" name="service" class="w-full px-8 py-5 rounded-2xl border border-gray-200 focus:outline-none focus:ring-4 focus:ring-brand-red/10 focus:border-brand-red transition-all bg-white font-bold text-gray-700">
							<option>Construcción de Pozos</option>
							<option>Excavaciones y Tierras</option>
							<option>Perforaciones Especiales</option>
							<option>Legalización / Otros</option>
						</select>
					</div>

					<div class="space-y-4 mb-12">
						<label for="message" class="block text-sm font-black text-brand-blue uppercase tracking-widest">Mensaje / Detalles</label>
						<textarea id="message" name="message" rows="5" class="w-full px-8 py-5 rounded-2xl border border-gray-200 focus:outline-none focus:ring-4 focus:ring-brand-red/10 focus:border-brand-red transition-all font-semibold" placeholder="Cuéntenos sobre su obra..."></textarea>
					</div>

					<button type="submit" class="btn-primary w-full text-2xl py-6 !flex items-center justify-center gap-6 shadow-2xl shadow-brand-red/30 group">
						Enviar Solicitud Profesional
						<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-2 group-hover:-translate-y-2"><path d="M22 2 11 13"/><path d="m22 2-7 20-4-9-9-4Z"/></svg>
					</button>
				</form>
			</div>
		</div>
	</div>
</section>
