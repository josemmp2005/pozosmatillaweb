---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-100 py-16 border-t border-gray-200">
	<div class="container mx-auto px-4">
		<div
			class="flex flex-col md:flex-row justify-between items-start gap-12 mb-12"
		>
			<!-- Branding -->
			<div class="max-w-xs">
				<div class="flex items-center gap-3 mb-6">
					<div
						class="w-12 h-12 rounded-lg overflow-hidden flex items-center justify-center"
					>
						<img
							src="/logo.png"
							alt="Logo Pozos Matilla"
							class="w-full h-full object-contain"
						/>
					</div>
					<div class="flex flex-col">
						<span
							class="text-2xl font-bold font-passion text-brand-red tracking-tighter uppercase brand-text-shadow"
							>Pozos Matilla S.L.</span
						>
						<span
							class="text-2xl font-bold font-passion text-brand-blue tracking-tighter uppercase brand-text-shadow"
							>Pozos y Perforaciones</span
						>
					</div>
				</div>
				<p class="text-gray-500 text-sm leading-relaxed mb-6 italic">
					Especialistas en pozos y excavaciones con más de 30 años de
					experiencia técnica.
				</p>
				<div class="flex gap-4">
					<a
						href="#"
						class="w-10 h-10 bg-white border border-gray-200 rounded-full flex items-center justify-center text-brand-blue hover:bg-brand-red hover:text-white transition-all shadow-sm"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="lucide lucide-facebook"
							><path
								d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
							></path></svg
						>
					</a>
					<a
						href="#"
						class="w-10 h-10 bg-white border border-gray-200 rounded-full flex items-center justify-center text-brand-blue hover:bg-brand-red hover:text-white transition-all shadow-sm"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="lucide lucide-instagram"
							><rect
								width="20"
								height="20"
								x="2"
								y="2"
								rx="5"
								ry="5"></rect><path
								d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
							></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
							></line></svg
						>
					</a>
				</div>
			</div>

			<!-- Links -->
			<div class="grid grid-cols-2 gap-16">
				<div class="space-y-4">
					<h4
						class="text-brand-blue font-black uppercase text-sm tracking-widest border-b-2 border-brand-red w-fit pb-1"
					>
						Empresa
					</h4>
					<ul
						class="space-y-2 text-sm text-gray-600 font-medium tracking-wide"
					>
						<li>
							<a
								href="#inicio"
								class="hover:text-brand-red transition-colors"
								>Inicio</a
							>
						</li>
						<li>
							<a
								href="#servicios"
								class="hover:text-brand-red transition-colors"
								>Servicios</a
							>
						</li>
						<li>
							<a
								href="#empresa"
								class="hover:text-brand-red transition-colors"
								>Nosotros</a
							>
						</li>
						<li>
							<a
								href="#galeria"
								class="hover:text-brand-red transition-colors"
								>Proyectos</a
							>
						</li>
					</ul>
				</div>
				<div class="space-y-4">
					<h4
						class="text-brand-blue font-black uppercase text-sm tracking-widest border-b-2 border-brand-red w-fit pb-1"
					>
						Legal
					</h4>
					<ul
						class="space-y-2 text-sm text-gray-600 font-medium tracking-wide"
					>
						<li>
							<a
								href="#"
								class="hover:text-brand-red transition-colors"
								>Aviso Legal</a
							>
						</li>
						<li>
							<a
								href="#"
								class="hover:text-brand-red transition-colors"
								>Privacidad</a
							>
						</li>
						<li>
							<a
								href="#"
								class="hover:text-brand-red transition-colors"
								>Cookies</a
							>
						</li>
					</ul>
				</div>
			</div>

			<!-- CTA / Location -->
			<div class="space-y-6">
				<h4
					class="text-brand-blue font-black uppercase text-sm tracking-widest border-b-2 border-brand-red w-fit pb-1"
				>
					Nuestra Central
				</h4>
				<div class="flex items-start gap-4">
					<div
						class="p-2 bg-brand-red/10 rounded-lg text-brand-red transition-colors"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="lucide lucide-map-pin"
							><path
								d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
							></path><circle cx="12" cy="10" r="3"></circle></svg
						>
					</div>
					<div>
						<p
							class="text-sm font-bold text-gray-700 leading-tight uppercase"
						>
							Palma del Río
						</p>
						<p
							class="text-xs text-gray-500 font-semibold uppercase"
						>
							Córdoba, España
						</p>
					</div>
				</div>
				<a
					href="tel:+34608856110"
					class="btn-primary w-full text-center py-4 flex items-center justify-center gap-2"
				>
					Llamada Directa
				</a>
			</div>
		</div>

		<div
			class="pt-8 border-t border-gray-200 flex flex-col md:flex-row justify-between items-center gap-4"
		>
			<p
				class="text-xs text-gray-500 font-bold uppercase tracking-widest"
			>
				&copy; {currentYear} Pozos Matilla S.L. Todos los derechos reservados.
			</p>
		</div>
	</div>
</footer>
