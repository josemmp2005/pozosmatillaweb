---
const services = [
	{
		id: 'pozos',
		title: 'Construcción de Pozos',
		description: 'Más de 30 años de experiencia técnica en pozos para riego agrícola e industrial con garantía de caudal y legalización.',
		image: '/images/service-pozos.png',
		features: ['Estudio terreno', 'Obra civil', 'Mantenimiento', 'Legalización']
	},
	{
		id: 'excavaciones',
		title: 'Excavaciones y Tierras',
		description: 'Movimiento de tierras de gran volumen, nivelaciones precisas y excavaciones para cimientos industriales y residenciales.',
		image: '/images/service-excavaciones.png',
		features: ['Maquinaria propia', 'Nivelación láser', 'Cimentaciones', 'Retirada escombros']
	},
	{
		id: 'perforaciones',
		title: 'Perforaciones Especiales',
		description: 'Perforaciones verticales de gran profundidad para geotermia, captación de aguas profundas y micropilotajes.',
		image: '/images/service-perforaciones.png',
		features: ['Alta profundidad', 'Precisión vertical', 'Geotermia', 'Terrenos difíciles']
	}
];
---

<section id="servicios" class="py-24 bg-gray-50 overflow-hidden">
	<div class="container mx-auto px-4">
		<div class="text-center mb-16 max-w-3xl mx-auto reveal reveal-up">
			<h2 class="text-4xl md:text-5xl font-black text-brand-blue mb-4 tracking-tight uppercase">NUESTROS <span class="text-brand-red">SERVICIOS</span></h2>
			<div class="w-24 h-1 bg-brand-red mx-auto mb-6"></div>
			<p class="text-gray-600 text-lg font-medium leading-relaxed">
				Ofrecemos soluciones integrales en el sector de la construcción y captación de aguas, utilizando tecnología de vanguardia y maquinaria propia de última generación.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal-group">
			{services.map(service => (
				<div class="group bg-white rounded-2xl overflow-hidden shadow-xl border border-gray-100 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 reveal reveal-up">
					<div class="h-64 overflow-hidden relative">
						<img 
							src={service.image} 
							alt={service.title} 
							class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-brand-blue/60 to-transparent opacity-60"></div>
						<div class="absolute bottom-6 left-6">
							<h3 class="text-white text-3xl font-black tracking-tight drop-shadow-lg uppercase leading-none">{service.title}</h3>
						</div>
					</div>
					
					<div class="p-8">
						<p class="text-gray-600 mb-6 leading-relaxed font-medium">
							{service.description}
						</p>
						
						<ul class="space-y-3 mb-8">
							{service.features.map(feature => (
								<li class="flex items-center gap-3 text-sm text-gray-700 font-bold uppercase tracking-tight">
									<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#dc211c" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><path d="M20 6 9 17l-5-5"/></svg>
									{feature}
								</li>
							))}
						</ul>
						
						<a href="#contacto" class="inline-flex items-center gap-2 text-brand-red font-black uppercase tracking-wider text-sm transition-all hover:gap-4">
							Saber más
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-right"><path d="m9 18 6-6-6-6"/></svg>
						</a>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
