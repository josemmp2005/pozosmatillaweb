---
const services = [
	{
		id: 'pozos',
		title: 'Construcción de Pozos',
		description: 'Más de 30 años de experiencia técnica en pozos para riego agrícola e industrial con garantía de caudal y legalización.',
		image: '/images/service-pozos.png',
		features: ['Estudio terreno', 'Obra civil', 'Mantenimiento', 'Legalización']
	},
	{
		id: 'excavaciones',
		title: 'Excavaciones y Tierras',
		description: 'Movimiento de tierras de gran volumen, nivelaciones precisas y excavaciones para cimientos industriales y residenciales.',
		image: '/images/service-excavaciones.png',
		features: ['Maquinaria propia', 'Nivelación láser', 'Cimentaciones', 'Retirada escombros']
	},
	{
		id: 'perforaciones',
		title: 'Perforaciones Especiales',
		description: 'Perforaciones verticales de gran profundidad para geotermia, captación de aguas profundas y micropilotajes.',
		image: '/images/service-perforaciones.png',
		features: ['Alta profundidad', 'Precisión vertical', 'Geotermia', 'Terrenos difíciles']
	}
];
---

<section id="servicios" class="py-24 bg-gray-50 overflow-hidden relative">
	<!-- Background subtle pattern -->
	<div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#102f75 1px, transparent 1px); background-size: 32px 32px;"></div>

	<div class="container mx-auto px-4 relative z-10">
		<div class="text-center mb-20 max-w-3xl mx-auto reveal reveal-up">
			<div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-red/10 border border-brand-red/20 rounded-full mb-6">
				<span class="w-1.5 h-1.5 bg-brand-red rounded-full"></span>
				<span class="text-xs font-bold uppercase tracking-widest text-brand-red">Excelencia Técnica</span>
			</div>
			<h2 class="text-5xl md:text-6xl font-bold text-brand-blue mb-6 tracking-tighter uppercase leading-none">
				NUESTROS <span class="text-brand-red">SERVICIOS</span>
			</h2>
			<p class="text-gray-600 text-lg md:text-xl font-medium leading-relaxed">
				Ofrecemos soluciones integrales con tecnología de vanguardia y maquinaria propia, garantizando precisión en cada proyecto industrial y agrícola.
			</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-10 reveal-group">
			{services.map((service, index) => (
				<div class="group relative bg-white rounded-[40px] overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-gray-100 hover:shadow-[0_40px_80px_rgba(16,47,117,0.12)] transition-all duration-700 hover:-translate-y-3 reveal reveal-up">
					<!-- Visual Counter -->
					<span class="absolute top-4 right-8 text-9xl font-bold text-gray-50 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none select-none">
						{String(index + 1).padStart(2, '0')}
					</span>

					<div class="h-72 overflow-hidden relative">
						<img 
							src={service.image} 
							alt={service.title} 
							class="w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-110"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-brand-blue/80 via-brand-blue/20 to-transparent opacity-60 group-hover:opacity-40 transition-opacity duration-700"></div>
						
						<div class="absolute bottom-8 left-8 right-8">
							<h3 class="text-white text-3xl font-bold tracking-tighter drop-shadow-2xl uppercase leading-[0.9]">
								{service.title.split(' ').map((word, i) => (
									<span class="block">{word}</span>
								))}
							</h3>
						</div>
					</div>
					
					<div class="p-10 relative">
						<p class="text-gray-600 mb-8 leading-relaxed font-semibold text-lg">
							{service.description}
						</p>
						
						<ul class="space-y-4 mb-10">
							{service.features.map(feature => (
								<li class="flex items-center gap-4 text-sm text-gray-800 font-bold uppercase tracking-tight group/item">
									<div class="w-6 h-6 rounded-lg bg-brand-red/10 flex items-center justify-center transition-transform group-hover/item:rotate-12">
										<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#dc211c" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check"><path d="M20 6 9 17l-5-5"/></svg>
									</div>
									{feature}
								</li>
							))}
						</ul>
						
						<div class="pt-6 border-t border-gray-50">
							<a href="#contacto" class="btn-secondary w-full !py-4 flex items-center justify-center gap-3 text-sm font-bold uppercase tracking-widest bg-gray-50 hover:bg-brand-red hover:text-white border-transparent transition-all">
								Consultar Detalles
								<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
							</a>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
